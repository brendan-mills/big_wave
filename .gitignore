# ---------------------------------------------------------------------------
# Project data — never tracked. Includes raw RINEX, SNR, orbits, executables,
# results, plots, gnssrefl logs, and the EarthScope SSO token.
# ---------------------------------------------------------------------------
data/

# ---------------------------------------------------------------------------
# Belt-and-suspenders: explicit patterns for project-specific binary/data
# formats in case anything escapes data/.
# ---------------------------------------------------------------------------
*.Z
*.snr66
*.snr66.gz
*.sp3
*.sp3.gz
*.parquet
sso_tokens.json

# RINEX observations — uncompressed + compressed (the bulky raw data).
# RINEX 2: ssssDDD0.YYo (obs) / .YYd (Hatanaka); RINEX 3: .rnx / .crx.
# (.YYo.Z / .YYd.Z are already covered by *.Z above.)
*.[0-9][0-9]o
*.[0-9][0-9]d
*.[0-9][0-9]o.gz
*.[0-9][0-9]d.gz
*.rnx
*.crx
*.rnx.gz
*.crx.gz

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# macOS / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
